{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_input.notebook_path' | xargs npx prettier --write 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
