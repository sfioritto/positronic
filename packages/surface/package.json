  "devDependencies": {
    "@mdx-js/esbuild": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.0",
    "esbuild": "^0.27.0",
