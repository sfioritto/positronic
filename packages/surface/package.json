{
  "name": "@positronic/surface",
  "version": "0.0.78",
  "publishConfig": {
    "access": "public"
  },
  "description": "AI-powered UI generation for Positronic",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/types/index.d.ts",
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "tsc": "tsc --project tsconfig.json",
    "swc": "swc src -d dist/src",
    "prebuild": "node -e \"const fs=require('fs'),p=require('path'),d=p.dirname(require.resolve('./package.json'));const md=fs.readFileSync(p.join(d,'src/system-prompt.md'),'utf8');fs.writeFileSync(p.join(d,'src/system-prompt.gen.ts'),'export default '+JSON.stringify(md)+';\\n')\"",
    "build": "npm run prebuild && npm run tsc && npm run swc",
    "clean": "rm -rf tsconfig.tsbuildinfo dist node_modules src/system-prompt.gen.ts"
  },
  "dependencies": {
    "@positronic/core": "^0.0.78",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1",
    "zod-to-ts": "^1.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
