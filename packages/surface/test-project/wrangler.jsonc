{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "surface-test",
  "main": "src/index.ts",
  "rules": [{ "type": "Text", "globs": ["**/*.md"] }],
  "compatibility_date": "2025-04-04",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "../Dockerfile",
      "instance_type": "lite",
      "max_instances": 1
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "SANDBOX"
      }
    ]
  }
}
